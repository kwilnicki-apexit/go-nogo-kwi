{
    "version": "1.0",
    "updated": "2026-03-06",
    "updated_by": "admin",
    "rules": [
        {
            "id": "R1",
            "name_en": "Minimum test coverage",
            "field": "coverage",
            "operator": ">=",
            "threshold": 80,
            "unit": "%",
            "severity": "blocker",
            "description_en": "Test coverage must be at least 80%. Below this threshold the deployment is automatically rejected."
        },
        {
            "id": "R2",
            "name_en": "Zero critical bugs",
            "field": "critical_bugs",
            "operator": "==",
            "threshold": 0,
            "unit": "count",
            "severity": "blocker",
            "description_en": "Critical bug count must be 0. Any critical bug blocks deployment."
        },
        {
            "id": "R3",
            "name_en": "Minimum functional test pass rate",
            "field": "functional_pass_rate",
            "operator": ">=",
            "threshold": 95,
            "unit": "%",
            "severity": "blocker",
            "description_en": "At least 95% of functional tests must pass."
        },
        {
            "id": "R4",
            "name_en": "Minimum non-functional test pass rate",
            "field": "nonfunctional_pass_rate",
            "operator": ">=",
            "threshold": 90,
            "unit": "%",
            "severity": "warning",
            "description_en": "At least 90% of non-functional tests should pass. Below this threshold justification is required."
        }
    ]
}